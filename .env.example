# Adult Creator Content Pipeline - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# =============================================================================
# GEMINI API (Free Tier)
# =============================================================================
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/minute, 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# REDDIT API CREDENTIALS
# =============================================================================
# Create app at: https://www.reddit.com/prefs/apps
# Select "script" type for personal use automation
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=AdultCreatorBot/1.0 by u/your_username

# =============================================================================
# CREATOR PROFILE
# =============================================================================
# Your social media handle (used in content generation)
CREATOR_HANDLE=@yourhandle

# Your OnlyFans/Fansly/other platform URL
CREATOR_OF_URL=https://onlyfans.com/yourpage

# Your persona/niche (1-2 sentences for AI content generation)
# Examples:
#   "Fitness model and former athlete who loves outdoor adventures"
#   "Cosplay enthusiast creating detailed character transformations"
#   "Art student exploring creative self-expression through photography"
CREATOR_PERSONA=describe your persona/niche in 1-2 sentences for content generation

# =============================================================================
# OPTIONAL: POSTIZ INTEGRATION
# =============================================================================
# If you want to auto-post to other platforms via Postiz
# Leave blank if not using
POSTIZ_API_KEY=

# =============================================================================
# OPTIONAL: ADVANCED SETTINGS
# =============================================================================
# Reddit posting schedule (comma-separated hours, 24h format)
# Default: 10,14,18,22 (10am, 2pm, 6pm, 10pm)
REDDIT_POST_HOURS=10,14,18,22

# Maximum posts per day (safety limit)
MAX_DAILY_POSTS=4

# Account warming mode (true/false)
# Set to true for first 1-2 weeks to gradually build karma
WARMING_MODE=true

# Content generation batch size (how many items to generate per run)
CONTENT_BATCH_SIZE=5

# TikTok carousel dimensions (width x height)
TIKTOK_WIDTH=1080
TIKTOK_HEIGHT=1920

# Debug mode (true/false) - more verbose logging
DEBUG_MODE=false
