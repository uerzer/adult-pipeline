# Adult Creator Content Pipeline - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# =============================================================================
# REDDIT ACCOUNT (browser automation via nodriver — no API app needed)
# =============================================================================
# Just your Reddit login. No client_id/secret needed — we use a real browser.
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Target subreddits (comma-separated, no r/ prefix)
# These should be SFW-ish subreddits that allow selfies/teasers
REDDIT_SUBREDDITS=selfie,selfies,amihot,FreeCompliments

# =============================================================================
# CREATOR PROFILE
# =============================================================================
CREATOR_HANDLE=@yourhandle
CREATOR_OF_URL=https://onlyfans.com/yourpage
CREATOR_PERSONA=describe your persona/niche in 1-2 sentences

# =============================================================================
# LLM SETTINGS (optional — works with zero config)
# =============================================================================
# Content Brain uses free no-auth LLM APIs by default:
#   1. UncloseAI (hermes.ai.unturf.com) — primary
#   2. TorGPT (torgpt.space) — fallback
#   3. Pollinations text API — second fallback
#
# No API keys needed. Leave these blank unless you want to override.
# If you have a Gemini key, set it here and content_brain will prefer it.
GEMINI_API_KEY=

# =============================================================================
# SCHEDULING
# =============================================================================
# Reddit posting hours (24h format, comma-separated)
REDDIT_POST_HOURS=10,14,18,22

# Max posts per day (safety limit)
MAX_DAILY_POSTS=4

# Account warming (set true for first 2 weeks)
WARMING_MODE=true

# Content batch size per run
CONTENT_BATCH_SIZE=5

# =============================================================================
# TIKTOK
# =============================================================================
TIKTOK_WIDTH=1080
TIKTOK_HEIGHT=1920

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================
# Proxy for Reddit (residential recommended, SOCKS5 or HTTP)
# Leave blank to use direct connection
PROXY_URL=

# Postiz API for cross-platform posting
POSTIZ_API_KEY=

# Debug mode
DEBUG_MODE=false
